# API
API_PORT=3000
API_HOST=0.0.0.0
API_PREFIX=/api/v1
NODE_ENV=development

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_DIRECT_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# JWT
JWT_ACCESS_SECRET=replace-with-access-secret
JWT_REFRESH_SECRET=replace-with-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# DeepSeek
DEEPSEEK_API_KEY=replace-with-deepseek-api-key
DEEPSEEK_MODEL=deepseek-v4-flash

# CORS
CORS_ORIGIN=http://localhost:10086

# Expo Mobile
EXPO_PUBLIC_API_BASE_URL=http://192.168.5.64:3000/api/v1
